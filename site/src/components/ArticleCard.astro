---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  showTags?: boolean;
  headingLevel?: 2 | 3;
}

const { article, showTags = true, headingLevel = 2 } = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3';
const dateFormatter = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/articles/${article.id}/`}
  class="group rounded-lg border border-slate-200 bg-white p-6 shadow-sm transition hover:border-cyan-700 hover:shadow"
>
  <p class="text-sm font-medium text-slate-500">
    <time datetime={article.data.publishedAt.toISOString()}>
      {dateFormatter.format(article.data.publishedAt)}
    </time>
  </p>
  <Heading class="mt-3 text-xl font-semibold text-slate-950 group-hover:text-cyan-700">
    {article.data.title}
  </Heading>
  <p class="mt-3 text-sm leading-7 text-slate-600">{article.data.description}</p>
  {
    showTags && article.data.tags.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {article.data.tags.map((tag) => (
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-600">
            {tag}
          </span>
        ))}
      </div>
    )
  }
</a>
