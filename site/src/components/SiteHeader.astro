---
interface NavLink {
  href: string;
  label: string;
}

interface Props {
  variant?: 'default' | 'overlay';
  maxWidth?: 'wide' | 'narrow';
  links?: NavLink[];
}

const {
  variant = 'default',
  maxWidth = 'wide',
  links = [
    { href: '/about/', label: 'About' },
    { href: '/articles/', label: '記事' },
    { href: '/tags/', label: 'タグ' },
  ],
} = Astro.props;

const isOverlay = variant === 'overlay';
const maxWidthClass = maxWidth === 'narrow' ? 'max-w-4xl' : 'max-w-6xl';
---

<header class:list={[isOverlay ? 'absolute inset-x-0 top-0 z-20' : 'border-b border-slate-200 bg-white']}>
  <nav class:list={['mx-auto flex items-center justify-between px-5 py-5 sm:px-8', maxWidthClass]} aria-label="メインナビゲーション">
    <a href="/" class:list={['text-base font-semibold', isOverlay ? 'text-white' : 'text-slate-950']}>aidd.tokyo</a>
    {
      links.length > 0 && (
        <div
          class:list={[
            'flex items-center',
            isOverlay
              ? 'gap-1 rounded-full border border-white/15 bg-slate-950/35 p-1 text-sm text-white/85 backdrop-blur'
              : 'gap-4 text-sm font-semibold text-slate-600',
          ]}
        >
          {links.map((link) => (
            <a
              href={link.href}
              class:list={[
                'transition',
                isOverlay
                  ? 'rounded-full px-2.5 py-2 hover:bg-white/12 hover:text-white sm:px-3'
                  : 'hover:text-cyan-700',
              ]}
            >
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </nav>
</header>
