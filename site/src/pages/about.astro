---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const heroImage = '/images/hero-ai-workshop.webp';
const heroFallbackImage = '/images/hero-ai-workshop.png';

const principles = [
  {
    title: '実装で確かめる',
    description:
      'AIツールの印象や流行だけで判断せず、実際のコード、テスト、レビューを通して有効性を確認します。',
  },
  {
    title: '小さく共有する',
    description:
      '大きな成功事例だけでなく、日々の試行錯誤、失敗した指示、改善したワークフローも知見として残します。',
  },
  {
    title: '人の判断を残す',
    description:
      'AIに任せる範囲を広げながらも、設計意図、品質基準、最終判断を開発者が説明できる状態を重視します。',
  },
];

const audiences = [
  'AIエージェントを開発フローに取り入れたいソフトウェアエンジニア',
  'チームでAI支援開発を導入・運用したいテックリードやEM',
  'プロンプトだけでなく、レビュー・テスト・CIまで含めて改善したい人',
];

const activities = ['記事・チュートリアル', '勉強会・ハンズオン', 'ツール検証', '導入事例の共有'];
---

<BaseLayout
  title="About — aidd.tokyo"
  description="aidd.tokyo は AI駆動開発を学び、試し、共有する東京発のコミュニティです。"
  canonicalPath="/about/"
>
  <SiteHeader
    links={[
      { href: '/articles/', label: '記事' },
      { href: '/tags/', label: 'タグ' },
    ]}
  />

  <main>
    <section class="relative isolate min-h-[58svh] overflow-hidden bg-slate-950 text-white">
      <picture class="absolute inset-0 -z-20 h-full w-full">
        <source srcset={heroImage} type="image/webp" />
        <img
          src={heroFallbackImage}
          alt="AI駆動開発のワークショップをイメージした作業風景"
          class="h-full w-full object-cover"
          width="1774"
          height="887"
          loading="eager"
          decoding="async"
        />
      </picture>
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(2,6,23,0.92)_0%,rgba(15,23,42,0.76)_48%,rgba(15,23,42,0.32)_100%)]"></div>
      <div class="mx-auto flex min-h-[58svh] max-w-6xl items-end px-5 pb-14 pt-28 sm:px-8 lg:pb-18">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase text-cyan-200">About</p>
          <h1 class="mt-4 text-4xl font-bold leading-tight sm:text-5xl">AI駆動開発を、現場で使える知識と実践へ。</h1>
          <p class="mt-6 text-lg leading-8 text-slate-200">
            aidd.tokyo は、AIエージェント時代のソフトウェア開発を学び、試し、共有する東京発のコミュニティです。
          </p>
        </div>
      </div>
    </section>

    <section class="border-b border-slate-200 bg-white">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 py-16 sm:px-8 lg:grid-cols-[0.8fr_1.2fr] lg:py-20">
        <div>
          <p class="text-sm font-semibold text-red-600">Mission</p>
          <h2 class="mt-3 text-3xl font-bold text-slate-950 sm:text-4xl">AIと開発者の協働を、検証可能な形にする</h2>
        </div>
        <div class="text-base leading-8 text-slate-600">
          <p>
            AI駆動開発は、AIにすべてを任せることではありません。開発者が目的、制約、品質基準を明確にし、AIを調査・実装・検証のパートナーとして扱うための実践です。
          </p>
          <p class="mt-5">
            私たちは、ツールの使い方だけでなく、レビュー、テスト、CI、チーム運用まで含めて、再現しやすいワークフローとして知見を積み上げます。
          </p>
        </div>
      </div>
    </section>

    <section class="bg-stone-50">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 lg:py-20">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-cyan-700">Principles</p>
          <h2 class="mt-3 text-3xl font-bold text-slate-950 sm:text-4xl">大事にすること</h2>
        </div>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          {
            principles.map((principle) => (
              <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                <h3 class="text-lg font-semibold text-slate-950">{principle.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-600">{principle.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white">
      <div class="mx-auto grid max-w-6xl gap-10 px-5 py-16 sm:px-8 lg:grid-cols-2 lg:py-20">
        <div>
          <p class="text-sm font-semibold text-cyan-700">For whom</p>
          <h2 class="mt-3 text-3xl font-bold text-slate-950 sm:text-4xl">こんな人に向けています</h2>
          <ul class="mt-6 space-y-4 text-base leading-8 text-slate-600">
            {audiences.map((audience) => <li class="border-l-4 border-cyan-700 pl-4">{audience}</li>)}
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold text-red-600">Activities</p>
          <h2 class="mt-3 text-3xl font-bold text-slate-950 sm:text-4xl">活動内容</h2>
          <div class="mt-6 flex flex-wrap gap-3">
            {activities.map((activity) => (
              <span class="rounded-full border border-slate-300 bg-stone-50 px-4 py-2 text-sm font-semibold text-slate-700">
                {activity}
              </span>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/articles/" class="inline-flex min-h-11 items-center rounded-full bg-slate-950 px-4 text-sm font-semibold text-white transition hover:bg-cyan-900">
              記事を読む
            </a>
            <a href="/tags/" class="inline-flex min-h-11 items-center rounded-full border border-slate-300 px-4 text-sm font-semibold text-slate-700 transition hover:border-cyan-700 hover:text-cyan-700">
              タグから探す
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
