---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  title="記事一覧 — aidd.tokyo"
  description="aidd.tokyo の公開記事とチュートリアル一覧です。AI駆動開発の実践ノート、ワークフロー、ツール検証を新しい順に掲載します。"
  canonicalPath="/articles/"
>
  <SiteHeader
    maxWidth="narrow"
    links={[
      { href: '/about/', label: 'About' },
      { href: '/events/', label: 'イベント' },
      { href: '/tags/', label: 'タグ' },
    ]}
  />

  <main class="mx-auto max-w-4xl px-5 py-14 sm:px-8 sm:py-18">
    <header>
      <p class="text-sm font-semibold text-cyan-700">Articles</p>
      <h1 class="mt-3 text-4xl font-bold text-slate-950 sm:text-5xl">記事一覧</h1>
      <p class="mt-5 text-base leading-8 text-slate-600">
        AI駆動開発の実践ノート、チュートリアル、ツール検証を新しい順に掲載します。
      </p>
    </header>

    <section class="mt-10 grid gap-4">
      {
        articles.length > 0 ? (
          articles.map((article) => <ArticleCard article={article} />)
        ) : (
          <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-base leading-8 text-slate-700">
              公開中の記事はまだありません。記事の `draft` を外して公開すると、ここに表示されます。
            </p>
          </div>
        )
      }
    </section>
  </main>

  <SiteFooter maxWidth="narrow" />
</BaseLayout>
