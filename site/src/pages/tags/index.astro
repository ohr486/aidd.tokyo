---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const tagCounts = articles.reduce<Map<string, number>>((counts, article) => {
  for (const tag of article.data.tags) {
    counts.set(tag, (counts.get(tag) ?? 0) + 1);
  }

  return counts;
}, new Map());

const tags = [...tagCounts.entries()].sort(([a], [b]) => a.localeCompare(b, 'ja'));
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>タグ一覧 — aidd.tokyo</title>
		<meta name="description" content="aidd.tokyo の公開記事に設定されているタグ一覧です。" />
		<link rel="canonical" href="https://aidd.tokyo/tags/" />
		<meta name="theme-color" content="#0f172a" />
	</head>
	<body class="bg-stone-50 text-slate-950 antialiased">
		<header class="border-b border-slate-200 bg-white">
			<nav class="mx-auto flex max-w-4xl items-center justify-between px-5 py-5 sm:px-8" aria-label="メインナビゲーション">
				<a href="/" class="text-base font-semibold text-slate-950">aidd.tokyo</a>
				<a href="/#journal" class="text-sm font-semibold text-slate-600 transition hover:text-cyan-700">記事一覧へ</a>
			</nav>
		</header>

		<main class="mx-auto max-w-4xl px-5 py-14 sm:px-8 sm:py-18">
			<header>
				<p class="text-sm font-semibold text-cyan-700">Tags</p>
				<h1 class="mt-3 text-4xl font-bold text-slate-950 sm:text-5xl">タグ一覧</h1>
				<p class="mt-5 text-base leading-8 text-slate-600">
					公開記事に設定されているタグから、関連する記事を探せます。
				</p>
			</header>

			<section class="mt-10">
				{
					tags.length > 0 ? (
						<div class="flex flex-wrap gap-3">
							{tags.map(([tag, count]) => (
								<a
									href={`/tags/${encodeURIComponent(tag)}/`}
									class="inline-flex min-h-11 items-center rounded-full border border-slate-300 bg-white px-4 text-sm font-semibold text-slate-700 transition hover:border-cyan-700 hover:text-cyan-700"
								>
									{tag}
									<span class="ml-2 text-slate-500">{count}</span>
								</a>
							))}
						</div>
					) : (
						<div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
							<p class="text-base leading-8 text-slate-700">
								公開中の記事タグはまだありません。記事の `draft` を外して公開すると、ここにタグが表示されます。
							</p>
						</div>
					)
				}
			</section>
		</main>
	</body>
</html>
