---
import { getCollection, render } from 'astro:content';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const events = await getCollection('events', ({ data }) => !data.draft);

  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const dateFormatter = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZone: 'Asia/Tokyo',
});

const statusLabels = {
  upcoming: '開催予定',
  past: '開催終了',
  cancelled: '中止',
};

const statusClasses = {
  upcoming: 'border-cyan-200 bg-cyan-50 text-cyan-800',
  past: 'border-slate-200 bg-slate-50 text-slate-600',
  cancelled: 'border-red-200 bg-red-50 text-red-700',
};

const eventPath = `/events/${event.id}/`;
const ogImage = event.data.coverImage?.src;
---

<BaseLayout
  title={`${event.data.title} — aidd.tokyo`}
  description={event.data.description ?? `${event.data.title} のイベント情報です。`}
  canonicalPath={eventPath}
  ogType="article"
  ogImage={ogImage}
>
  <SiteHeader
    maxWidth="narrow"
    links={[
      { href: '/events/', label: 'イベント一覧' },
      { href: '/articles/', label: '記事' },
      { href: '/tags/', label: 'タグ' },
    ]}
  />

  <main>
    <article class="mx-auto max-w-4xl px-5 py-14 sm:px-8 sm:py-18">
      <div class="flex flex-wrap gap-3">
        <a href="/events/" class="inline-flex min-h-10 items-center rounded-full border border-slate-300 px-4 text-sm font-semibold text-slate-700 transition hover:border-cyan-700 hover:text-cyan-700">
          イベント一覧へ
        </a>
        {
          event.data.connpassUrl && (
            <a
              href={event.data.connpassUrl}
              class="inline-flex min-h-10 items-center rounded-full bg-slate-950 px-4 text-sm font-semibold text-white transition hover:bg-cyan-900"
            >
              参加ページを開く
            </a>
          )
        }
      </div>

      <header class="mt-10 border-b border-slate-200 pb-10">
        <div class="flex flex-wrap items-center gap-2">
          <span class:list={['rounded-full border px-3 py-1 text-xs font-semibold', statusClasses[event.data.status]]}>
            {statusLabels[event.data.status]}
          </span>
          <time class="text-sm font-medium text-cyan-700" datetime={event.data.date.toISOString()}>
            {dateFormatter.format(event.data.date)}
          </time>
        </div>
        <h1 class="mt-4 text-4xl font-bold leading-tight text-slate-950 sm:text-5xl">{event.data.title}</h1>
        {event.data.description && <p class="mt-5 text-lg leading-8 text-slate-600">{event.data.description}</p>}
        <dl class="mt-7 grid gap-4 rounded-lg border border-slate-200 bg-white p-5 text-sm sm:grid-cols-2">
          <div>
            <dt class="font-semibold text-slate-500">日時</dt>
            <dd class="mt-1 text-slate-900">
              <time datetime={event.data.date.toISOString()}>{dateFormatter.format(event.data.date)}</time>
            </dd>
          </div>
          <div>
            <dt class="font-semibold text-slate-500">会場</dt>
            <dd class="mt-1 text-slate-900">
              {
                event.data.venueUrl ? (
                  <a href={event.data.venueUrl} class="transition hover:text-cyan-700">
                    {event.data.venue}
                  </a>
                ) : (
                  event.data.venue
                )
              }
            </dd>
          </div>
        </dl>
      </header>

      <div class="article-content mt-10">
        <Content />
      </div>
    </article>
  </main>

  <SiteFooter maxWidth="narrow" />
</BaseLayout>
