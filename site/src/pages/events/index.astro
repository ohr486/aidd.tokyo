---
import { getCollection } from 'astro:content';
import EventCard from '../../components/EventCard.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const events = await getCollection('events', ({ data }) => !data.draft);
const upcomingEvents = events
  .filter((event) => event.data.status === 'upcoming')
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const pastEvents = events
  .filter((event) => event.data.status === 'past')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const cancelledEvents = events
  .filter((event) => event.data.status === 'cancelled')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="イベント — aidd.tokyo"
  description="aidd.tokyo の勉強会、ハンズオン、知見共有イベントの一覧です。"
  canonicalPath="/events/"
>
  <SiteHeader
    maxWidth="narrow"
    links={[
      { href: '/about/', label: 'About' },
      { href: '/articles/', label: '記事' },
      { href: '/tags/', label: 'タグ' },
    ]}
  />

  <main class="mx-auto max-w-4xl px-5 py-14 sm:px-8 sm:py-18">
    <header>
      <p class="text-sm font-semibold text-cyan-700">Events</p>
      <h1 class="mt-3 text-4xl font-bold text-slate-950 sm:text-5xl">イベント</h1>
      <p class="mt-5 text-base leading-8 text-slate-600">
        AI駆動開発の実践を扱う勉強会、ハンズオン、知見共有の予定と記録を掲載します。
      </p>
    </header>

    <section class="mt-10">
      <div class="flex items-end justify-between gap-4 border-b border-slate-200 pb-4">
        <div>
          <p class="text-sm font-semibold text-cyan-700">Upcoming</p>
          <h2 class="mt-2 text-2xl font-bold text-slate-950">開催予定</h2>
        </div>
        <p class="text-sm text-slate-500">{upcomingEvents.length}件</p>
      </div>
      <div class="mt-5 grid gap-4">
        {
          upcomingEvents.length > 0 ? (
            upcomingEvents.map((event) => <EventCard event={event} />)
          ) : (
            <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <p class="text-base leading-8 text-slate-700">
                開催予定のイベントは準備中です。公開後はここに日時と参加方法が表示されます。
              </p>
            </div>
          )
        }
      </div>
    </section>

    {
      pastEvents.length > 0 && (
        <section class="mt-12">
          <div class="flex items-end justify-between gap-4 border-b border-slate-200 pb-4">
            <div>
              <p class="text-sm font-semibold text-slate-500">Archive</p>
              <h2 class="mt-2 text-2xl font-bold text-slate-950">開催終了</h2>
            </div>
            <p class="text-sm text-slate-500">{pastEvents.length}件</p>
          </div>
          <div class="mt-5 grid gap-4">
            {pastEvents.map((event) => (
              <EventCard event={event} />
            ))}
          </div>
        </section>
      )
    }

    {
      cancelledEvents.length > 0 && (
        <section class="mt-12">
          <div class="flex items-end justify-between gap-4 border-b border-slate-200 pb-4">
            <div>
              <p class="text-sm font-semibold text-red-600">Cancelled</p>
              <h2 class="mt-2 text-2xl font-bold text-slate-950">中止</h2>
            </div>
            <p class="text-sm text-slate-500">{cancelledEvents.length}件</p>
          </div>
          <div class="mt-5 grid gap-4">
            {cancelledEvents.map((event) => (
              <EventCard event={event} />
            ))}
          </div>
        </section>
      )
    }
  </main>

  <SiteFooter maxWidth="narrow" />
</BaseLayout>
